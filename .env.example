# Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Groq API Configuration
# # Get your key from: https://console.groq.com/
# GROQ_API_KEY=your_groq_api_key_here

# # HuggingFace API Configuration
# # Get your token from: https://huggingface.co/settings/tokens
# HF_API_KEY=your_huggingface_api_key_here
GROQ_API_KEY="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"
HF_API_TOKEN="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"
# LLM Model Configuration
# Available models: mixtral-8x7b-32768, llama-2-70b-chat, llama-3.1-8b-instant, etc.
LLM_MODEL=mixtral-8x7b-32768

# Image Generation Model
# Options: stabilityai/stable-diffusion-3-medium, stabilityai/stable-diffusion-xl-base-1.0
IMAGE_MODEL=stabilityai/stable-diffusion-3-medium

# LLM Parameters
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=2048

# Storage Configuration
STORAGE_TYPE=json
DATA_DIR=data

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Application
APP_DEBUG=False
